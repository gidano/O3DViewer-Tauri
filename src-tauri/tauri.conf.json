{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "O3D Viewer",
  "version": "0.1.8",
  "identifier": "hu.gidano.o3dviewer",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../frontend-dist"
  },
  "app": {
    "windows": [
      {
        "title": "O3D Viewer",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "maximized": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  }
}
